# FILE: .env.example
# (Create this file in the ROOT of your project — same level as package.json)


# TaskFlow — Environment Variables

#
# SETUP INSTRUCTIONS:
# 1. Copy this file and rename it to .env.local
#    Command: cp .env.example .env.local
#
# 2. Replace the placeholder values with your actual Firebase config
#
# 3. NEVER commit .env.local to Git
#    (It is already in .gitignore, but double-check)
#
# 4. Every variable MUST start with VITE_ to be accessible
#    in browser code. This is a Vite security feature.
#
# ============================================

# ──────────────────────────────────────────
# FIREBASE CONFIGURATION
# ──────────────────────────────────────────
# These values come from your Firebase Console:
# Firebase Console → Project Settings → General → Your apps → Web app
#
# Each value identifies and configures the connection to your
# specific Firebase project. Without these, the app cannot
# communicate with Firebase services.

# API Key — Identifies your Firebase project to Google's servers.
# Despite the name "API Key," this is NOT a secret in Firebase's model.
# It is safe to expose in client-side code. Access control is handled
# by Firestore Security Rules, not by this key.
VITE_FIREBASE_API_KEY=your_api_key_here

# Auth Domain — The domain used for Firebase Authentication.
# Format: your-project-id.firebaseapp.com
VITE_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com

# Project ID — Your unique Firebase project identifier.
# This is used in Firestore URLs and Cloud Functions.
VITE_FIREBASE_PROJECT_ID=your_project_id_here

# Storage Bucket — The Cloud Storage bucket for file uploads.
# Format: your-project-id.appspot.com (or .firebasestorage.app)
VITE_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com

# Messaging Sender ID — Used for Firebase Cloud Messaging (push notifications).
# We may not use push notifications, but Firebase config includes it.
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id_here

# App ID — Unique identifier for your specific web app within the Firebase project.
# A Firebase project can have multiple apps (web, iOS, Android).
VITE_FIREBASE_APP_ID=your_app_id_here

# Measurement ID (Optional) — Used for Google Analytics integration.
# Only needed if you enable Google Analytics in Firebase.
# You can leave this empty if not using analytics.
VITE_FIREBASE_MEASUREMENT_ID=your_measurement_id_here

# ──────────────────────────────────────────
# APPLICATION CONFIGURATION
# ──────────────────────────────────────────

# App Name — Used in page titles, emails, and UI
VITE_APP_NAME=TaskFlow

# App URL — The base URL of the deployed application.
# Used for generating shareable links and OAuth redirect URLs.
# In development, this is http://localhost:5173
VITE_APP_URL=http://localhost:5173
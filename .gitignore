# FILE: .gitignore

# ============================================
# Dependencies
# ============================================
node_modules/

# ============================================
# Build Output
# ============================================
dist/
dist-ssr/
build/

# ============================================
# Environment Variables (CRITICAL — never commit secrets)
# ============================================
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.development
.env.production

# ============================================
# Editor & IDE
# ============================================
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.swp
*.swo
*~

# ============================================
# Operating System
# ============================================
.DS_Store
Thumbs.db
desktop.ini

# ============================================
# Debug Logs
# ============================================
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ============================================
# Firebase
# ============================================
.firebase/
firebase-debug.log
firestore-debug.log
ui-debug.log

# ============================================
# Misc
# ============================================
*.local
*.tsbuildinfo
coverage/